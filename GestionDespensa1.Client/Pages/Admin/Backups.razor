@page "/admin/backups"
@using GestionDespensa1.Client.Servicios.Entidades
@using GestionDespensa1.Client.Servicios.Http
@using GestionDespensa1.Shared.DTO
@inject IHttpServicio HttpServicio
@inject NavigationManager Navigation
@inject IJSRuntime JS

<PageTitle>Backups - Gestión Despensa</PageTitle>

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="mb-0">
            <i class="fas fa-database text-success me-2"></i>
            Copias de Seguridad (Backups)
        </h2>
        <button class="btn btn-outline-secondary" @onclick="Volver">
            <i class="fas fa-arrow-left me-1"></i> Volver
        </button>
    </div>

    <!-- Botón crear backup -->
    <div class="row mb-4">
        <div class="col-12">
            <button class="btn btn-success btn-lg" @onclick="CrearBackup" disabled="@creando">
                @if (creando)
                {
                    <span class="spinner-border spinner-border-sm me-2"></span>
                }
                <i class="fas fa-save me-2"></i> Crear Backup Ahora
            </button>
            <small class="text-muted ms-3">
                Los backups automáticos se realizan todos los días a las 3:00 AM
            </small>
        </div>
    </div>

    <!-- Lista de backups -->
    <div class="card shadow">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0"><i class="fas fa-history me-2"></i>Backups Disponibles</h5>
        </div>
        <div class="card-body">
            @if (cargando)
            {
                <div class="text-center p-5">
                    <div class="spinner-border text-success" role="status">
                        <span class="visually-hidden">Cargando...</span>
                    </div>
                    <p class="mt-3">Cargando backups...</p>
                </div>
            }
            else if (!backups.Any())
            {
                <div class="alert alert-info text-center p-5">
                    <i class="fas fa-database fa-4x mb-3 text-muted"></i>
                    <h5>No hay backups disponibles</h5>
                    <p>Crea tu primer backup haciendo clic en el botón superior.</p>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-striped table-hover">
                        <thead class="table-dark">
                            <tr>
                                <th>#</th>
                                <th>Nombre del Archivo</th>
                                <th>Fecha de Creación</th>
                                <th>Tamaño</th>
                                <th class="text-center">Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @for (int i = 0; i < backups.Count; i++)
                            {
                                var backup = backups[i];
                                <tr>
                                    <td>@(i + 1)</td>
                                    <td class="fw-bold">@backup.FileName</td>
                                    <td>@backup.CreationDate.ToString("dd/MM/yyyy HH:mm:ss")</td>
                                    <td>@backup.FileSizeFormatted</td>
                                    <td class="text-center">
                                        <button class="btn btn-sm btn-info me-1" @onclick="() => DescargarBackup(backup.FileName)" title="Descargar">
                                            <i class="fas fa-download"></i>
                                        </button>
                                        <button class="btn btn-sm btn-warning me-1" @onclick="() => RestaurarBackup(backup.FileName)" title="Restaurar">
                                            <i class="fas fa-undo"></i>
                                        </button>
                                        <button class="btn btn-sm btn-danger" @onclick="() => EliminarBackup(backup.FileName)" title="Eliminar">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>

@code {
    private List<BackupInfoDTO> backups = new();
    private bool cargando = true;
    private bool creando = false;

    protected override async Task OnInitializedAsync()
    {
        await CargarBackups();
    }

    private async Task CargarBackups()
    {
        cargando = true;
        StateHasChanged();

        try
        {
            var respuesta = await HttpServicio.Get<List<BackupInfoDTO>>("api/Backup/listar");
            if (!respuesta.Error)
            {
                backups = respuesta.Respuesta ?? new();
            }
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("alert", $"Error: {ex.Message}");
        }

        cargando = false;
        StateHasChanged();
    }

    private async Task CrearBackup()
    {
        creando = true;
        StateHasChanged();

        try
        {
            var respuesta = await HttpServicio.Post<object, BackupInfoDTO>("api/Backup/crear", new { });
            if (!respuesta.Error && respuesta.Respuesta?.Success == true)
            {
                await JS.InvokeVoidAsync("alert", $"✅ Backup creado: {respuesta.Respuesta.FileName} ({respuesta.Respuesta.FileSizeFormatted})");
                await CargarBackups();
            }
            else
            {
                await JS.InvokeVoidAsync("alert", $"❌ Error: {respuesta.Respuesta?.Message ?? "Error desconocido"}");
            }
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("alert", $"❌ Error: {ex.Message}");
        }

        creando = false;
        StateHasChanged();
    }

    private async Task DescargarBackup(string fileName)
    {
        await JS.InvokeVoidAsync("open", $"/api/Backup/descargar/{fileName}", "_blank");
    }

    private async Task RestaurarBackup(string fileName)
    {
        var confirmado = await JS.InvokeAsync<bool>("confirm",
            $"⚠️ ¿Está SEGURO de restaurar el backup {fileName}?\n\n" +
            "Esta acción reemplazará TODOS los datos actuales con los del backup.\n" +
            "Se recomienda hacer un backup actual antes de continuar.");

        if (!confirmado) return;

        try
        {
            var respuesta = await HttpServicio.Post<object, string>($"api/Backup/restaurar/{fileName}", new { });
            if (!respuesta.Error)
            {
                await JS.InvokeVoidAsync("alert", "✅ Backup restaurado correctamente. La aplicación se reiniciará.");
                Navigation.NavigateTo("/", true);
            }
            else
            {
                await JS.InvokeVoidAsync("alert", $"❌ Error al restaurar");
            }
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("alert", $"❌ Error: {ex.Message}");
        }
    }

    private async Task EliminarBackup(string fileName)
    {
        var confirmado = await JS.InvokeAsync<bool>("confirm",
            $"¿Eliminar el backup {fileName}?");

        if (!confirmado) return;

        // Implementar eliminación si es necesario
        await JS.InvokeVoidAsync("alert", "Función no implementada");
    }

    private void Volver()
    {
        Navigation.NavigateTo("/");
    }
}