    private void ActualizarHora(string? horaSeleccionada)
    {
        if (!string.IsNullOrEmpty(horaSeleccionada))
        {
            // Parsear la hora seleccionada (formato HH:mm)
            if (TimeSpan.TryParse(horaSeleccionada, out TimeSpan hora))
            {
                // Crear nueva fecha manteniendo la fecha actual pero cambiando la hora
                venta.FechaVenta = new DateTime(
                    venta.FechaVenta.Year,
                    venta.FechaVenta.Month,
                    venta.FechaVenta.Day,
                    hora.Hours,
                    hora.Minutes,
                    0  // Segundos a 0
                );
            }
        }
    }
    // Agrega este método para manejar el cambio manual de estado
    private void OnEstadoChanged(ChangeEventArgs e)
    {
        // Validación segura contra nulos
        string? nuevoEstado = e.Value as string ?? e.Value?.ToString();

        if (!string.IsNullOrWhiteSpace(nuevoEstado))
        {
            venta.Estado = nuevoEstado;

            // Si el usuario selecciona "Pagado", ajustar automáticamente el monto pagado
            if (venta.Estado == "Pagado" && venta.MontoPagado < venta.Total)
            {
                venta.MontoPagado = venta.Total;
                venta.SaldoPendiente = 0;

                // Mostrar mensaje al usuario (opcional)
                _ = JS.InvokeVoidAsync("alert", "Se ha ajustado automáticamente el monto pagado al total.");
            }
            // Si el usuario selecciona "Pendiente" pero el monto pagado es igual al total
            else if (venta.Estado == "Pendiente" && venta.MontoPagado >= venta.Total)
            {
                venta.MontoPagado = 0;
                venta.SaldoPendiente = venta.Total;
            }

            StateHasChanged();
        }
    }

    private void AgregarDetalle()
    {
        if (detalleSeleccionado.IdProducto == 0)
        {
            JS.InvokeVoidAsync("alert", "Seleccione un producto");
            return;
        }

        if (detalleSeleccionado.Cantidad <= 0 || detalleSeleccionado.PrecioUnitario <= 0)
        {
            JS.InvokeVoidAsync("alert", "Cantidad y precio deben ser mayores a 0");
            return;
        }

        if (!TieneStockSuficiente())
        {
            var producto = productosDisponibles.FirstOrDefault(p => p.Id == detalleSeleccionado.IdProducto);
            if (producto != null)
            {
                JS.InvokeVoidAsync("alert", $"Stock insuficiente. Disponible: {producto.StockActual}");
            }
            return;
        }

        var productoSeleccionado = productosDisponibles.FirstOrDefault(p => p.Id == detalleSeleccionado.IdProducto);
        string nombreProducto = productoSeleccionado?.Descripcion ?? "Producto desconocido";

        if (detalleEditando && detalleOriginal != null)
        {
            var index = detallesVenta.IndexOf(detalleOriginal);
            if (index >= 0)
            {
                detallesVenta[index] = new DetalleVentaDTO
                {
                    IdProducto = detalleSeleccionado.IdProducto,
                    DescripcionProducto = nombreProducto,
                    Cantidad = detalleSeleccionado.Cantidad,
                    PrecioUnitario = detalleSeleccionado.PrecioUnitario,
                    StockActual = detalleSeleccionado.StockActual
                };
            }
        }
        else
        {
            detallesVenta.Add(new DetalleVentaDTO
            {
                IdProducto = detalleSeleccionado.IdProducto,
                DescripcionProducto = nombreProducto,
                Cantidad = detalleSeleccionado.Cantidad,
                PrecioUnitario = detalleSeleccionado.PrecioUnitario,
                StockActual = detalleSeleccionado.StockActual
            });
        }

        ActualizarTotales();
        CerrarModalProducto();
    }

    private void EditarDetalle(DetalleVentaDTO detalle)
