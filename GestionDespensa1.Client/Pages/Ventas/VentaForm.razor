            {
                detallesVenta.Add(new DetalleVentaDTO
                {
                    IdProducto = respuesta.Respuesta,
                    DescripcionProducto = productoNuevoNombre.Trim(),
                    Cantidad = productoNuevoCantidad,
                    PrecioUnitario = Math.Round(productoNuevoPrecioFinal, 2),
                    StockActual = productoNuevoCantidad
                });

                await CargarProductos();
                ActualizarTotales();
                CerrarModalProductoNuevo();
                await JS.InvokeVoidAsync("alert", "✅ Producto agregado y guardado en catálogo");
            }
            else
            {
                var mensajeError = await respuesta.ObtenerError();
                await JS.InvokeVoidAsync("alert", $"❌ Error: {mensajeError}");
            }
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("alert", $"❌ Error: {ex.Message}");
        }
    }

