        productoNuevoCantidad > 0 &&
        productoNuevoPrecioUnitario > 0 &&
        productoNuevoGananciaPorcentaje >= 0 &&
        productoNuevoPrecioFinal > 0 &&
        productoNuevoStockMinimo > 0;

