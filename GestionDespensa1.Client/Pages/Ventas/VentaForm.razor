    // ============ MÉTODOS DE PAGO ============
    private void OnPagoEfectivoChanged(ChangeEventArgs e)
    {
        var nuevoValor = ParseDecimalCorregido(e.Value);
        pagoEfectivo = nuevoValor;

        if (pagoEfectivo > TotalVenta)
            pagoEfectivo = TotalVenta;

        if (pagoEfectivo + pagoTransferencia + pagoTarjeta > TotalVenta)
        {
            pagoEfectivo = TotalVenta - pagoTransferencia - pagoTarjeta;
            if (pagoEfectivo < 0) pagoEfectivo = 0;
        }

        ActualizarPagos();
    }

    private void OnPagoTransferenciaChanged(ChangeEventArgs e)
    {
        var nuevoValor = ParseDecimalCorregido(e.Value);
        pagoTransferencia = nuevoValor;

        if (pagoTransferencia > TotalVenta)
            pagoTransferencia = TotalVenta;

        if (pagoEfectivo + pagoTransferencia + pagoTarjeta > TotalVenta)
        {
            pagoTransferencia = TotalVenta - pagoEfectivo - pagoTarjeta;
            if (pagoTransferencia < 0) pagoTransferencia = 0;
        }

