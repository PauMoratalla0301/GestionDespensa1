    private async Task GuardarNuevaCategoria()
    {
        if (string.IsNullOrWhiteSpace(nuevaCategoria.NombreCategoria))
        {
            await JS.InvokeVoidAsync("alert", "El nombre de la categoría es obligatorio");
            return;
        }

        guardandoCategoria = true;
        StateHasChanged();

        try
        {
            var respuesta = await CategoriaService.Insert(nuevaCategoria);

            if (!respuesta.Error && respuesta.Respuesta > 0)
            {
                await CargarCategorias();
                productoNuevoCategoriaId = respuesta.Respuesta;
                mostrarModalCategoria = false;
                await JS.InvokeVoidAsync("alert", "✅ Categoría creada exitosamente");
            }
            else
            {
                var mensajeError = await respuesta.ObtenerError();
                await JS.InvokeVoidAsync("alert", $"❌ Error: {mensajeError}");
            }
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("alert", $"❌ Error: {ex.Message}");
        }
        finally
        {
            guardandoCategoria = false;
            StateHasChanged();
        }
    }

