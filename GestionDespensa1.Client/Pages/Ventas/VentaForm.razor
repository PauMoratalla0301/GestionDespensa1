    private void CalcularPrecioFinalProductoNuevo()
    {
        if (productoNuevoPrecioUnitario > 0 && productoNuevoGananciaPorcentaje >= 0)
        {
            productoNuevoGanancia = productoNuevoPrecioUnitario * (productoNuevoGananciaPorcentaje / 100);
            productoNuevoPrecioFinal = productoNuevoPrecioUnitario + productoNuevoGanancia;
            Console.WriteLine($"💰 Producto nuevo - Precio Unit.: {productoNuevoPrecioUnitario:C}, Ganancia: {productoNuevoGananciaPorcentaje}%, Monto ganancia: {productoNuevoGanancia:C}, Precio Final: {productoNuevoPrecioFinal:C}");
        }
        else
        {
            productoNuevoGanancia = 0;
            productoNuevoPrecioFinal = productoNuevoPrecioUnitario;
            Console.WriteLine($"💰 Producto nuevo - Precio Final (sin ganancia): {productoNuevoPrecioFinal:C}");
        }
        StateHasChanged();
    }

    private decimal CalcularPrecioFinal(decimal precioUnitario, decimal gananciaPorcentaje)
    {
        if (precioUnitario > 0 && gananciaPorcentaje >= 0)
        {
            decimal ganancia = precioUnitario * (gananciaPorcentaje / 100);
            return precioUnitario + ganancia;
        }
        return precioUnitario;
    }

    private bool PuedeAgregarProductoNuevo =>
