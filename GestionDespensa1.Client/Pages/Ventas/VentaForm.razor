    private void OnPagoTarjetaChanged(ChangeEventArgs e)
    {
        var nuevoValor = ParseDecimalCorregido(e.Value);
        pagoTarjeta = nuevoValor;

        if (pagoTarjeta > TotalVenta)
            pagoTarjeta = TotalVenta;

        if (pagoEfectivo + pagoTransferencia + pagoTarjeta > TotalVenta)
        {
