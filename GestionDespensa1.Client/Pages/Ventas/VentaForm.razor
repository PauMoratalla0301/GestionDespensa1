            Console.WriteLine($"💰 Venta PENDIENTE - Total: {venta.Total:C}, Sin pagos");
        }

        StateHasChanged();
    }

    private void PagarTodo()
    {
        var saldoRestante = SaldoPendiente;

        if (Id > 0)
        {
            if (venta.IdCliente == 0)
            {
                pagoEfectivo = TotalVenta - (pagoTransferencia + pagoTarjeta);
                if (pagoEfectivo < 0) pagoEfectivo = 0;
            }
            else
            {
                if (pagoEfectivo == 0 && pagoTransferencia == 0 && pagoTarjeta == 0)
                {
                    pagoEfectivo = saldoRestante;
                }
                else
                {
                    var totalActual = TotalPagado;
                    if (totalActual > 0)
                    {
                        var factor = saldoRestante / totalActual;
                        if (pagoEfectivo > 0) pagoEfectivo += pagoEfectivo * factor;
                        if (pagoTransferencia > 0) pagoTransferencia += pagoTransferencia * factor;
                        if (pagoTarjeta > 0) pagoTarjeta += pagoTarjeta * factor;
                    }
                }
            }
        }
        else
        {
            if (venta.IdCliente == 0)
            {
                pagoEfectivo = TotalVenta;
                pagoTransferencia = 0;
                pagoTarjeta = 0;
            }
            else
            {
                if (pagoEfectivo == 0 && pagoTransferencia == 0 && pagoTarjeta == 0)
                {
                    pagoEfectivo = saldoRestante;
                }
                else
                {
                    var totalActual = TotalPagado;
                    if (totalActual > 0)
                    {
                        if (pagoEfectivo > 0) pagoEfectivo += (pagoEfectivo / totalActual) * saldoRestante;
                        if (pagoTransferencia > 0) pagoTransferencia += (pagoTransferencia / totalActual) * saldoRestante;
                        if (pagoTarjeta > 0) pagoTarjeta += (pagoTarjeta / totalActual) * saldoRestante;
                    }
                }
            }
        }

        pagoEfectivo = Math.Round(pagoEfectivo, 2);
        pagoTransferencia = Math.Round(pagoTransferencia, 2);
        pagoTarjeta = Math.Round(pagoTarjeta, 2);

        ActualizarPagos();

        Console.WriteLine($"💰 PagarTodo - Efectivo: {pagoEfectivo:C}, Transf: {pagoTransferencia:C}, Tarjeta: {pagoTarjeta:C}");
    }

    private int ObtenerInt(object value)
    {
        if (value == null) return 0;
        if (value is int intValue) return intValue;
        if (value is string strValue && int.TryParse(strValue, out int result)) return result;
        return 0;
    }

    private void ActualizarTotales()
    {
        venta.Total = TotalVenta;
        ActualizarPagos();
