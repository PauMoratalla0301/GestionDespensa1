    private async Task GuardarVenta()
    {
        if (Id == 0)
        {
            var respuestaCaja = await CajaService.HayCajaAbiertaHoy();
            if (respuestaCaja.Error || !respuestaCaja.Respuesta)
            {
                await JS.InvokeVoidAsync("alert", "❌ No se puede realizar la venta porque no hay una caja abierta para hoy.\n\n👉 Por favor, vaya a Cajas y abra una caja primero.");
                Navigation.NavigateTo("/cajas/nuevo");
                return;
            }
        }

        cargando = true;
        StateHasChanged();

        if (!detallesVenta.Any())
        {
            await JS.InvokeVoidAsync("alert", "Debe agregar al menos un producto");
            cargando = false;
            StateHasChanged();
            return;
        }

        ActualizarPagos();

        if (venta.IdCliente == 0 && venta.SaldoPendiente > 0.01m)
        {
            await JS.InvokeVoidAsync("alert", "❌ Cliente ocasional no puede tener saldo pendiente. Debe pagar el total.");
            cargando = false;
            StateHasChanged();
            return;
        }

        Console.WriteLine($"💰 ANTES DE GUARDAR - Total: {venta.Total:C}, Pagado: {venta.MontoPagado:C}, Saldo: {venta.SaldoPendiente:C}, Estado: {venta.Estado}");

        if (Id == 0) // NUEVA VENTA
        {
            // Crear objeto anónimo con la estructura que espera el backend
            var nuevaVenta = new CrearVentaDTO
            {
                IdCliente = venta.IdCliente == 0 ? 1 : venta.IdCliente,
                IdUsuario = venta.IdUsuario,
                FechaVenta = venta.FechaVenta,
                Estado = venta.Estado,
                Total = Math.Round(venta.Total, 2),
                MontoPagado = Math.Round(venta.MontoPagado, 2),
                SaldoPendiente = Math.Round(venta.SaldoPendiente, 2),
                MetodoPago = venta.MetodoPago,
                Notas = venta.Notas,
                DetallesVenta = detallesVenta.Select(d => new DetalleVentaDTO
                {
                    IdProducto = d.IdProducto,
                    Cantidad = d.Cantidad,
                    PrecioUnitario = Math.Round(d.PrecioUnitario, 2)
                }).ToList()
            };

            Console.WriteLine($"📝 Guardando venta - Estado final: {crearVenta.Estado}");

            var respuesta = await VentaService.Insert(crearVenta);

            if (!respuesta.Error && respuesta.Respuesta > 0)
            {
                await JS.InvokeVoidAsync("alert", "✅ Venta creada exitosamente");
                Navigation.NavigateTo("/ventas");
            }
            else
            {
                var mensajeError = await respuesta.ObtenerError();
                await JS.InvokeVoidAsync("alert", $"❌ Error: {mensajeError}");
            }
        }
        else // EDICIÓN
        {
            venta.DetallesVenta = detallesVenta;
            var respuesta = await VentaService.Update(Id, venta);

            if (!respuesta.Error)
            {
                await JS.InvokeVoidAsync("alert", "✅ Venta actualizada exitosamente");
                Navigation.NavigateTo("/ventas");
            }
            else
            {
                var mensajeError = await respuesta.ObtenerError();
                await JS.InvokeVoidAsync("alert", $"❌ Error: {mensajeError}");
            }
        }

        cargando = false;
        StateHasChanged();
    }

    private void Cancelar() => Navigation.NavigateTo("/ventas");
    private async Task ImprimirTicket()
    {
        await JS.InvokeVoidAsync("window.print");
    }

    private void HandleKeyPress(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && mostrarModalProducto)
        {
            AgregarDetalle();
        }
        else if (e.Key == "Escape")
        {
            CerrarModalProducto();
        }
    }
