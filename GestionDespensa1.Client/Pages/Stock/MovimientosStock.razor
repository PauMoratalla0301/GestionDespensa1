@page "/stock/movimientos"
@using GestionDespensa1.Client.Servicios.Auth
@using GestionDespensa1.Client.Servicios.Entidades
@using GestionDespensa1.Shared.DTO
@inject IMovimientoStockService MovimientoStockService
@inject IProductoService ProductoService
@inject NavigationManager Navigation

<PageTitle>Movimientos de Stock - GestionDespensa</PageTitle>

<div class="container-fluid">
    <h2 class="mb-4">📊 Historial de Movimientos de Stock</h2>

    <!-- Filtros -->
    <div class="card mb-4">
        <div class="card-header bg-info text-white">
            <h5 class="mb-0"><i class="fas fa-filter me-2"></i>Filtros</h5>
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-4">
                    <div class="form-group">
                        <label class="form-label fw-bold">Producto</label>
                        <select @bind="filtroProductoId" class="form-control">
                            <option value="0">Todos los productos</option>
                            @foreach (var producto in productos)
                            {
                                <option value="@producto.Id">@producto.Descripcion</option>
                            }
                        </select>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="form-group">
                        <label class="form-label fw-bold">Tipo</label>
                        <select @bind="filtroTipo" class="form-control">
                            <option value="">Todos</option>
                            <option value="VENTA">Venta</option>
                            <option value="COMPRA">Compra</option>
                            <option value="AJUSTE">Ajuste</option>
                        </select>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="form-group">
                        <label class="form-label fw-bold">Fecha desde</label>
                        <input type="date" @bind="fechaDesde" class="form-control" />
                    </div>
                </div>
                <div class="col-md-2 d-flex align-items-end">
                    <button class="btn btn-primary w-100" @onclick="AplicarFiltros">
                        <i class="fas fa-search me-2"></i>Filtrar
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Tabla de movimientos -->
    <div class="card">
        <div class="card-header bg-success text-white">
            <h5 class="mb-0"><i class="fas fa-history me-2"></i>Movimientos</h5>
        </div>
        <div class="card-body">
            @if (cargando)
            {
                <div class="text-center p-4">
                    <div class="spinner-border text-success" role="status">
                        <span class="visually-hidden">Cargando...</span>
                    </div>
                    <p class="mt-2">Cargando movimientos...</p>
                </div>
            }
            else if (!movimientos.Any())
            {
                <div class="alert alert-info text-center p-4">
                    <i class="fas fa-box-open fa-3x mb-3"></i>
                    <h5>No hay movimientos para mostrar</h5>
                    <p>Los movimientos aparecerán cuando realices ventas o ajustes de stock.</p>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-striped table-hover">
                        <thead class="table-dark">
                            <tr>
                                <th>Fecha</th>
                                <th>Producto</th>
                                <th>Tipo</th>
                                <th>Cantidad</th>
                                <th>Stock Anterior</th>
                                <th>Stock Nuevo</th>
                                <th>Referencia</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var mov in movimientos)
                            {
                                <tr>
                                    <td>@mov.Fecha.ToString("dd/MM/yyyy HH:mm")</td>
                                    <td class="fw-bold">@mov.NombreProducto</td>
                                    <td>
                                        <span class="badge @GetTipoBadge(mov.Tipo)">@mov.Tipo</span>
                                    </td>
                                    <td class="fw-bold @(mov.Tipo == "VENTA" ? "text-danger" : "text-success")">
                                        @(mov.Tipo == "VENTA" ? "-" : "+")@mov.Cantidad
                                    </td>
                                    <td>@mov.StockAnterior</td>
                                    <td class="fw-bold">@mov.StockNuevo</td>
                                    <td><small class="text-muted">@mov.Referencia</small></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>

@code {
    private List<MovimientoStockDTO> movimientos = new();
    private List<ProductoDTO> productos = new();
    private int filtroProductoId = 0;
    private string filtroTipo = "";
    private DateTime? fechaDesde;
    private bool cargando = true;

    protected override async Task OnInitializedAsync()
    {
        await CargarProductos();
        await CargarMovimientos();
    }

    private async Task CargarProductos()
    {
        var respuesta = await ProductoService.Get();
        if (!respuesta.Error)
        {
            productos = respuesta.Respuesta ?? new();
        }
    }

    private async Task CargarMovimientos()
    {
        cargando = true;
        StateHasChanged();

        var respuesta = await MovimientoStockService.Get();
        if (!respuesta.Error)
        {
            movimientos = respuesta.Respuesta ?? new();
            AplicarFiltrosLocales();
        }

        cargando = false;
        StateHasChanged();
    }

    private async Task AplicarFiltros()
    {
        cargando = true;
        StateHasChanged();

        var respuesta = filtroProductoId > 0
            ? await MovimientoStockService.GetByProducto(filtroProductoId)
            : await MovimientoStockService.Get();

        if (!respuesta.Error)
        {
            movimientos = respuesta.Respuesta ?? new();
            AplicarFiltrosLocales();
        }

        cargando = false;
        StateHasChanged();
    }

    private void AplicarFiltrosLocales()
    {
        if (!string.IsNullOrEmpty(filtroTipo))
        {
            movimientos = movimientos.Where(m => m.Tipo == filtroTipo).ToList();
        }

        if (fechaDesde.HasValue)
        {
            movimientos = movimientos.Where(m => m.Fecha.Date >= fechaDesde.Value.Date).ToList();
        }
    }

    private string GetTipoBadge(string tipo)
    {
        return tipo switch
        {
            "VENTA" => "bg-danger",
            "COMPRA" => "bg-success",
            "AJUSTE" => "bg-warning",
            _ => "bg-secondary"
        };
    }
}