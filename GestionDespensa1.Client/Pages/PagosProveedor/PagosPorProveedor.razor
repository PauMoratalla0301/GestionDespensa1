@page "/pagos-proveedor"
@using GestionDespensa1.Client.Servicios.Auth
@using GestionDespensa1.Client.Servicios.Entidades
@using GestionDespensa1.Shared.DTO
@inject IPagoProveedorService PagoProveedorService
@inject IProveedorService ProveedorService
@inject NavigationManager Navigation
@inject IJSRuntime JS

<PageTitle>Pagos a Proveedores - Gestión Despensa</PageTitle>

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="mb-0">
            <i class="fas fa-hand-holding-usd text-success me-2"></i>
            Pagos a Proveedores
        </h2>
        <button class="btn btn-outline-secondary" @onclick="Volver">
            <i class="fas fa-arrow-left me-1"></i> Volver
        </button>
    </div>

    <!-- Selector de proveedor -->
    <div class="card mb-4 shadow">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0"><i class="fas fa-filter me-2"></i>Seleccionar Proveedor</h5>
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-8">
                    <label class="form-label fw-bold">Proveedor</label>
                    <select @bind="proveedorSeleccionadoId" class="form-select">
                        <option value="0">-- Seleccione un proveedor --</option>
                        @foreach (var prov in proveedores)
                        {
                            <option value="@prov.Id">@prov.Nombre</option>
                        }
                    </select>
                </div>
                <div class="col-md-4 d-flex align-items-end">
                    <button class="btn btn-success w-100" @onclick="CargarPagos" disabled="@cargando">
                        <i class="fas fa-search me-2"></i> Ver Pagos
                    </button>
                </div>
            </div>
        </div>
    </div>

    @if (cargando)
    {
        <div class="text-center p-5">
            <div class="spinner-border text-success" style="width: 3rem; height: 3rem;" role="status">
                <span class="visually-hidden">Cargando...</span>
            </div>
            <p class="mt-3">Cargando pagos...</p>
        </div>
    }
    else if (pagos != null && pagos.Any())
    {
        <!-- Resumen -->
        <div class="row mb-4">
            <div class="col-md-6">
                <div class="card text-white bg-success">
                    <div class="card-body">
                        <h6 class="card-title">Total Pagado</h6>
                        <h3 class="mb-0">@pagos.Sum(p => p.Monto).ToString("C")</h3>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="card text-white bg-info">
                    <div class="card-body">
                        <h6 class="card-title">Cantidad de Pagos</h6>
                        <h3 class="mb-0">@pagos.Count</h3>
                    </div>
                </div>
            </div>
        </div>

        <!-- Tabla de pagos -->
        <div class="card shadow">
            <div class="card-header bg-success text-white">
                <h5 class="mb-0"><i class="fas fa-list me-2"></i>Historial de Pagos</h5>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-striped table-hover">
                        <thead class="table-dark">
                            <tr>
                                <th>#</th>
                                <th>Fecha</th>
                                <th>Compra</th>
                                <th>Monto</th>
                                <th>Medio de Pago</th>
                                <th>Observaciones</th>
                                <th>Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var pago in pagos)
                            {
                                <tr>
                                    <td>@pago.Id</td>
                                    <td>@pago.Fecha.ToString("dd/MM/yyyy HH:mm")</td>
                                    <td>
                                        <a href="javascript:void(0)" @onclick="() => VerCompra(pago.IdCompra)">
                                            Compra #@pago.IdCompra
                                        </a>
                                    </td>
                                    <td class="fw-bold text-success">@pago.Monto.ToString("C")</td>
                                    <td>@pago.MedioPago</td>
                                    <td>@pago.Observaciones</td>
                                    <td>
                                        <button class="btn btn-sm btn-info" @onclick="() => VerCompra(pago.IdCompra)">
                                            <i class="fas fa-eye"></i> Ver Compra
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
    else if (proveedorSeleccionadoId > 0)
    {
        <div class="alert alert-info">
            <i class="fas fa-info-circle me-2"></i>
            No hay pagos registrados para este proveedor.
        </div>
    }
</div>

@code {
    private List<ProveedorDTO> proveedores = new();
    private List<PagoProveedorDTO>? pagos;
    private int proveedorSeleccionadoId;
    private bool cargando = false;

    protected override async Task OnInitializedAsync()
    {
        await CargarProveedores();
    }

    private async Task CargarProveedores()
    {
        var respuesta = await ProveedorService.Get();
        if (!respuesta.Error)
        {
            proveedores = respuesta.Respuesta ?? new();
        }
    }

    private async Task CargarPagos()
    {
        if (proveedorSeleccionadoId == 0)
        {
            await JS.InvokeVoidAsync("alert", "Debe seleccionar un proveedor");
            return;
        }

        cargando = true;
        StateHasChanged();

        var respuesta = await PagoProveedorService.GetByProveedor(proveedorSeleccionadoId);
        if (!respuesta.Error)
        {
            pagos = respuesta.Respuesta;
        }
        else
        {
            await JS.InvokeVoidAsync("alert", "Error al cargar los pagos");
        }

        cargando = false;
        StateHasChanged();
    }

    private void VerCompra(int idCompra)
    {
        Navigation.NavigateTo($"/compras/detalles/{idCompra}");
    }

    private void Volver()
    {
        Navigation.NavigateTo("/");
    }
}