@page "/compras/detalles/{Id:int}"
@using GestionDespensa1.Client.Servicios.Entidades
@using GestionDespensa1.Shared.DTO
@inject ICompraProveedorService CompraService
@inject IPagoProveedorService PagoProveedorService
@inject NavigationManager Navigation
@inject IJSRuntime JS

<PageTitle>Detalle de Compra - Gestión Despensa</PageTitle>

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="mb-0">
            <i class="fas fa-shopping-cart text-success me-2"></i>
            Detalle de Compra #@Id
        </h2>
        <div class="d-flex gap-2">
            <button class="btn btn-info" @onclick="DescargarComprobante">
                <i class="fas fa-file-pdf me-1"></i> Descargar Comprobante
            </button>
            <button class="btn btn-outline-secondary" @onclick="Volver">
                <i class="fas fa-arrow-left me-1"></i> Volver
            </button>
        </div>
    </div>

    @if (cargando)
    {
        <div class="text-center p-5">
            <div class="spinner-border text-success" role="status">
                <span class="visually-hidden">Cargando...</span>
            </div>
            <p class="mt-3">Cargando detalles...</p>
        </div>
    }
    else if (compra == null)
    {
        <div class="alert alert-danger">Compra no encontrada</div>
    }
    else
    {
        <!-- Información de la compra -->
        <div class="card mb-4 shadow">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0"><i class="fas fa-info-circle me-2"></i>Información General</h5>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-4">
                        <p><strong>Proveedor:</strong> @compra.NombreProveedor</p>
                    </div>
                    <div class="col-md-4">
                        <p><strong>Fecha:</strong> @compra.FechaCompra.ToString("dd/MM/yyyy HH:mm")</p>
                    </div>
                    <div class="col-md-4">
                        <p>
                            <strong>Estado:</strong>
                            <span class="badge @(compra.Estado == "PAGADA" ? "bg-success" : "bg-warning")">
                                @compra.Estado
                            </span>
                        </p>
                    </div>
                </div>
                <div class="row">
                    <div class="col-md-4">
                        <p><strong>Total:</strong> <span class="fw-bold text-success">@compra.Total.ToString("C")</span></p>
                    </div>
                    <div class="col-md-4">
                        <p><strong>Pagado:</strong> <span class="fw-bold text-success">@(compra.PagadoTotal?.ToString("C") ?? "$0.00")</span></p>
                    </div>
                    <div class="col-md-4">
                        <p>
                            <strong>Pendiente:</strong>
                            <span class="fw-bold @(pendiente > 0 ? "text-danger" : "text-success")">
                                @pendiente.ToString("C")
                            </span>
                        </p>
                    </div>
                </div>
                @if (!string.IsNullOrEmpty(compra.Observaciones))
                {
                    <div class="row">
                        <div class="col-12">
                            <p><strong>Observaciones:</strong> @compra.Observaciones</p>
                        </div>
                    </div>
                }
            </div>
        </div>

        <!-- Productos -->
        <div class="card mb-4 shadow">
            <div class="card-header bg-success text-white">
                <h5 class="mb-0"><i class="fas fa-boxes me-2"></i>Productos</h5>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-striped">
                        <thead>
                            <tr>
                                <th>Producto</th>
                                <th class="text-center">Cantidad</th>
                                <th class="text-end">Precio Unit.</th>
                                <th class="text-end">Subtotal</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in compra.DetallesCompra)
                            {
                                <tr>
                                    <td>@item.DescripcionProducto</td>
                                    <td class="text-center">@item.Cantidad</td>
                                    <td class="text-end">@item.PrecioUnitario.ToString("C")</td>
                                    <td class="text-end fw-bold">@((item.Cantidad * item.PrecioUnitario).ToString("C"))</td>
                                </tr>
                            }
                        </tbody>
                        <tfoot>
                            <tr>
                                <td colspan="3" class="text-end fw-bold">TOTAL:</td>
                                <td class="text-end fw-bold text-success fs-5">@compra.Total.ToString("C")</td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
        </div>
    }
</div>

@code {
    [Parameter] public int Id { get; set; }

    private CompraProveedorDTO? compra;
    private bool cargando = true;
    private decimal pendiente => (compra?.Total ?? 0) - (compra?.PagadoTotal ?? 0);

    protected override async Task OnInitializedAsync()
    {
        await CargarCompra();
    }

    private async Task CargarCompra()
    {
        cargando = true;
        StateHasChanged();

        var respuesta = await CompraService.Get(Id);
        if (!respuesta.Error)
        {
            compra = respuesta.Respuesta;
        }

        cargando = false;
        StateHasChanged();
    }

    private async Task DescargarComprobante()
    {
        try
        {
            await JS.InvokeVoidAsync("open", $"/api/Comprobantes/compra/{Id}", "_blank");
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("alert", $"Error: {ex.Message}");
        }
    }

    private void Volver()
    {
        Navigation.NavigateTo("/compras");
    }
}