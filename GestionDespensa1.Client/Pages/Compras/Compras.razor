@page "/compras"
@using GestionDespensa1.Client.Servicios.Auth
@using GestionDespensa1.Client.Servicios.Entidades
@using GestionDespensa1.Shared.DTO
@inject ICompraProveedorService CompraService
@inject IProveedorService ProveedorService
@inject NavigationManager Navigation
@inject IJSRuntime JS

<PageTitle>Compras - GestionDespensa</PageTitle>

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="mb-0">
            <i class="fas fa-shopping-cart text-success me-2"></i>
            Compras a Proveedores
        </h2>
        <button class="btn btn-success" @onclick="NuevaCompra">
            <i class="fas fa-plus me-1"></i> Nueva Compra
        </button>
    </div>

    <!-- Filtros -->
    <div class="card mb-4 shadow-sm">
        <div class="card-header bg-info text-white">
            <h5 class="mb-0"><i class="fas fa-filter me-2"></i>Filtros</h5>
        </div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-4">
                    <label class="form-label fw-bold">Proveedor</label>
                    <select @bind="filtroProveedorId" class="form-select">
                        <option value="0">Todos los proveedores</option>
                        @foreach (var proveedor in proveedores)
                        {
                            <option value="@proveedor.Id">@proveedor.Nombre</option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-bold">Estado</label>
                    <select @bind="filtroEstado" class="form-select">
                        <option value="">Todos</option>
                        <option value="PENDIENTE">Pendiente</option>
                        <option value="PAGADA">Pagada</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-bold">Fecha desde</label>
                    <input type="date" @bind="fechaDesde" class="form-control" />
                </div>
                <div class="col-md-2 d-flex align-items-end">
                    <button class="btn btn-primary w-100" @onclick="AplicarFiltros">
                        <i class="fas fa-search me-2"></i> Filtrar
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Tabla de compras -->
    <div class="card shadow">
        <div class="card-header bg-success text-white">
            <h5 class="mb-0"><i class="fas fa-list me-2"></i>Lista de Compras</h5>
        </div>
        <div class="card-body">
            @if (cargando)
            {
                <div class="text-center p-5">
                    <div class="spinner-border text-success" style="width: 3rem; height: 3rem;" role="status">
                        <span class="visually-hidden">Cargando...</span>
                    </div>
                    <p class="mt-3">Cargando compras...</p>
                </div>
            }
            else if (!compras.Any())
            {
                <div class="alert alert-info text-center p-5">
                    <i class="fas fa-shopping-cart fa-4x mb-3 text-muted"></i>
                    <h5>No hay compras registradas</h5>
                    <p>Las compras aparecerán cuando registres una nueva compra a proveedores.</p>
                    <button class="btn btn-success mt-3" @onclick="NuevaCompra">
                        <i class="fas fa-plus me-2"></i>Nueva Compra
                    </button>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-striped table-hover">
                        <thead class="table-dark">
                            <tr>
                                <th>#</th>
                                <th>Fecha</th>
                                <th>Proveedor</th>
                                <th>Productos</th>
                                <th class="text-end">Total</th>
                                <th class="text-end">Pagado</th>
                                <th class="text-end">Pendiente</th>
                                <th>Estado</th>
                                <th class="text-center">Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var compra in comprasFiltradas)
                            {
                                var pendiente = compra.Total - (compra.PagadoTotal ?? 0);
                                <tr>
                                    <td>@compra.Id</td>
                                    <td>@compra.FechaCompra.ToString("dd/MM/yyyy")</td>
                                    <td class="fw-bold">@compra.NombreProveedor</td>
                                    <td>
                                        <span class="badge bg-info">@compra.DetallesCompra?.Count productos</span>
                                    </td>
                                    <td class="text-end fw-bold text-success">$@compra.Total.ToString("N2")</td>
                                    <td class="text-end fw-bold text-primary">$@(compra.PagadoTotal?.ToString("N2") ?? "0.00")</td>
                                    <td class="text-end fw-bold @(pendiente > 0 ? "text-danger" : "text-success")">
                                        $@pendiente.ToString("N2")
                                    </td>
                                    <td>
                                        <span class="badge @GetEstadoBadge(compra.Estado)">@compra.Estado</span>
                                    </td>
                                    <td class="text-center">
                                        <div class="btn-group btn-group-sm" role="group">
                                            <button class="btn btn-info" @onclick="() => VerDetalles(compra.Id)" title="Ver detalles">
                                                <i class="fas fa-eye"></i>
                                            </button>
                                            <button class="btn btn-warning" @onclick="() => EditarCompra(compra.Id)" title="Editar">
                                                <i class="fas fa-edit"></i>
                                            </button>
                                            <button class="btn btn-success" @onclick="() => DescargarComprobante(compra.Id)" title="Comprobante PDF">
                                                <i class="fas fa-file-pdf"></i>
                                            </button>
                                            <button class="btn btn-danger" @onclick="() => EliminarCompra(compra.Id)" title="Eliminar">
                                                <i class="fas fa-trash"></i>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>

<style>
    .btn-group .btn {
        margin: 0 2px;
    }
</style>

@code {
    private List<CompraProveedorDTO> compras = new();
    private List<CompraProveedorDTO> comprasFiltradas = new();
    private List<ProveedorDTO> proveedores = new();
    private int filtroProveedorId = 0;
    private string filtroEstado = "";
    private DateTime? fechaDesde;
    private bool cargando = true;

    protected override async Task OnInitializedAsync()
    {
        await CargarProveedores();
        await CargarCompras();
    }

    private async Task CargarProveedores()
    {
        var respuesta = await ProveedorService.Get();
        if (!respuesta.Error)
        {
            proveedores = respuesta.Respuesta ?? new();
        }
    }

    private async Task CargarCompras()
    {
        cargando = true;
        StateHasChanged();

        var respuesta = await CompraService.Get();
        if (!respuesta.Error)
        {
            compras = respuesta.Respuesta ?? new();
            AplicarFiltros();
        }

        cargando = false;
        StateHasChanged();
    }

    private void AplicarFiltros()
    {
        var filtrados = compras.AsEnumerable();

        if (filtroProveedorId > 0)
        {
            filtrados = filtrados.Where(c => c.IdProveedor == filtroProveedorId);
        }

        if (!string.IsNullOrEmpty(filtroEstado))
        {
            filtrados = filtrados.Where(c => c.Estado == filtroEstado);
        }

        if (fechaDesde.HasValue)
        {
            filtrados = filtrados.Where(c => c.FechaCompra.Date >= fechaDesde.Value.Date);
        }

        comprasFiltradas = filtrados.OrderByDescending(c => c.FechaCompra).ToList();
    }

    private string GetEstadoBadge(string estado)
    {
        return estado switch
        {
            "PENDIENTE" => "bg-warning text-dark",
            "PAGADA" => "bg-success",
            _ => "bg-secondary"
        };
    }

    private void NuevaCompra()
    {
        Navigation.NavigateTo("/compras/nueva");
    }

    private void VerDetalles(int id)
    {
        Navigation.NavigateTo($"/compras/detalles/{id}");
    }

    private void EditarCompra(int id)
    {
        Navigation.NavigateTo($"/compras/editar/{id}");
    }

    private async Task DescargarComprobante(int id)
    {
        try
        {
            await JS.InvokeVoidAsync("open", $"/api/Comprobantes/compra/{id}", "_blank");
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("alert", $"Error al abrir comprobante: {ex.Message}");
        }
    }

    private async Task EliminarCompra(int id)
    {
        var compra = compras.FirstOrDefault(c => c.Id == id);
        if (compra == null) return;

        var confirmado = await JS.InvokeAsync<bool>("confirm",
            $"¿Está seguro de eliminar la compra #{compra.Id} a {compra.NombreProveedor} por ${compra.Total:N2}?");

        if (confirmado)
        {
            var respuesta = await CompraService.Delete(id);
            if (!respuesta.Error)
            {
                await CargarCompras();
                await JS.InvokeVoidAsync("alert", "✅ Compra eliminada correctamente");
            }
            else
            {
                var error = await respuesta.ObtenerError();
                await JS.InvokeVoidAsync("alert", $"❌ Error: {error}");
            }
        }
    }
}