@page "/reportes/productos"
@using GestionDespensa1.Client.Servicios.Entidades
@using GestionDespensa1.Shared.DTO
@inject IReportesService ReportesService
@inject NavigationManager Navigation
@inject IJSRuntime JS

<PageTitle>Productos Más Vendidos - Gestión Despensa</PageTitle>

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="mb-0">
            <i class="fas fa-chart-pie text-success me-2"></i>
            Productos Más Vendidos
        </h2>
        <div>
            <button class="btn btn-success me-2" @onclick="ExportarExcel">
                <i class="fas fa-file-excel me-1"></i> Exportar a Excel
            </button>
            <button class="btn btn-outline-secondary" @onclick="Volver">
                <i class="fas fa-arrow-left me-1"></i> Volver
            </button>
        </div>
    </div>

    <!-- Filtros -->
    <div class="card mb-4 shadow">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0"><i class="fas fa-filter me-2"></i>Seleccionar Período</h5>
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-5">
                    <label class="form-label fw-bold">Fecha Inicio</label>
                    <input type="date" @bind="fechaInicio" class="form-control" />
                </div>
                <div class="col-md-5">
                    <label class="form-label fw-bold">Fecha Fin</label>
                    <input type="date" @bind="fechaFin" class="form-control" />
                </div>
                <div class="col-md-2 d-flex align-items-end">
                    <button class="btn btn-success w-100" @onclick="CargarReporte" disabled="@cargando">
                        <i class="fas fa-search me-2"></i> Buscar
                    </button>
                </div>
            </div>
        </div>
    </div>

    @if (cargando)
    {
        <div class="text-center p-5">
            <div class="spinner-border text-success" style="width: 3rem; height: 3rem;" role="status">
                <span class="visually-hidden">Cargando...</span>
            </div>
            <p class="mt-3">Generando reporte...</p>
        </div>
    }
    else if (reporte != null)
    {
        <!-- Resumen -->
        <div class="row mb-4">
            <div class="col-md-8">
                <div class="card text-white bg-info">
                    <div class="card-body">
                        <h6 class="card-title">Período</h6>
                        <h5 class="mb-0">@reporte.FechaInicio.ToString("dd/MM/yyyy") - @reporte.FechaFin.ToString("dd/MM/yyyy")</h5>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card bg-warning">
                    <div class="card-body">
                        <h6 class="card-title">Total Productos</h6>
                        <h3 class="mb-0">@reporte.Productos.Count</h3>
                    </div>
                </div>
            </div>
        </div>

        <!-- Tabla de productos -->
        <div class="card shadow">
            <div class="card-header bg-success text-white">
                <h5 class="mb-0"><i class="fas fa-trophy me-2"></i>Top Productos</h5>
            </div>
            <div class="card-body">
                @if (!reporte.Productos.Any())
                {
                    <div class="alert alert-info">No hay ventas en el período seleccionado</div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-striped table-hover">
                            <thead class="table-dark">
                                <tr>
                                    <th>#</th>
                                    <th>Producto</th>
                                    <th>Categoría</th>
                                    <th class="text-center">Cantidad Vendida</th>
                                    <th class="text-end">Total Vendido</th>
                                </tr>
                            </thead>
                            <tbody>
                                @{
                                    int i = 1;
                                }
                                @foreach (var prod in reporte.Productos)
                                {
                                    <tr>
                                        <td><span class="badge @(i <= 3 ? "bg-warning" : "bg-secondary") fs-6">@i</span></td>
                                        <td class="fw-bold">@prod.Producto</td>
                                        <td>@prod.Categoria</td>
                                        <td class="text-center">@prod.CantidadVendida</td>
                                        <td class="text-end fw-bold text-success">@prod.TotalVendido.ToString("C")</td>
                                    </tr>
                                    i++;
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    }
</div>

@code {
    private DateTime fechaInicio = DateTime.Today.AddDays(-30);
    private DateTime fechaFin = DateTime.Today;
    private ReporteProductosDTO? reporte;
    private bool cargando = false;

    protected override async Task OnInitializedAsync()
    {
        await CargarReporte();
    }

    private async Task CargarReporte()
    {
        cargando = true;
        StateHasChanged();

        var respuesta = await ReportesService.GetProductosMasVendidos(fechaInicio, fechaFin);
        if (!respuesta.Error)
        {
            reporte = respuesta.Respuesta;
        }
        else
        {
            await JS.InvokeVoidAsync("alert", "Error al cargar el reporte");
        }

        cargando = false;
        StateHasChanged();
    }

    private async Task ExportarExcel()
    {
        try
        {
            string url = $"/api/Exportar/productos/excel?fechaInicio={fechaInicio:yyyy-MM-dd}&fechaFin={fechaFin:yyyy-MM-dd}";
            await JS.InvokeVoidAsync("open", url, "_blank");
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("alert", $"Error al exportar: {ex.Message}");
        }
    }

    private void Volver()
    {
        Navigation.NavigateTo("/");
    }
}