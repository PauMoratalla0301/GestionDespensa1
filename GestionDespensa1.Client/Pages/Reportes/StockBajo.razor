@page "/reportes/stock-bajo"
@using GestionDespensa1.Client.Servicios.Entidades
@using GestionDespensa1.Shared.DTO
@inject IReportesService ReportesService
@inject NavigationManager Navigation
@inject IJSRuntime JS

<PageTitle>Stock Bajo - Gestión Despensa</PageTitle>

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="mb-0">
            <i class="fas fa-exclamation-triangle text-warning me-2"></i>
            Productos con Stock Bajo
        </h2>
        <div>
            <button class="btn btn-success me-2" @onclick="ExportarExcel">
                <i class="fas fa-file-excel me-1"></i> Exportar a Excel
            </button>
            <button class="btn btn-outline-secondary" @onclick="Volver">
                <i class="fas fa-arrow-left me-1"></i> Volver
            </button>
        </div>
    </div>

    @if (cargando)
    {
        <div class="text-center p-5">
            <div class="spinner-border text-success" style="width: 3rem; height: 3rem;" role="status">
                <span class="visually-hidden">Cargando...</span>
            </div>
            <p class="mt-3">Cargando productos...</p>
        </div>
    }
    else if (reporte == null)
    {
        <div class="alert alert-danger">Error al cargar el reporte</div>
    }
    else
    {
        <!-- Resumen -->
        <div class="row mb-4">
            <div class="col-md-6">
                <div class="card text-white bg-danger">
                    <div class="card-body">
                        <h6 class="card-title">Productos con Stock Bajo</h6>
                        <h3 class="mb-0">@reporte.Productos.Count</h3>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="card text-white bg-info">
                    <div class="card-body">
                        <h6 class="card-title">Total Productos</h6>
                        <h3 class="mb-0">@reporte.TotalProductos</h3>
                    </div>
                </div>
            </div>
        </div>

        <!-- Tabla de productos -->
        <div class="card shadow">
            <div class="card-header bg-warning">
                <h5 class="mb-0">Productos que necesitan reposición</h5>
            </div>
            <div class="card-body">
                @if (!reporte.Productos.Any())
                {
                    <div class="alert alert-success">
                        <i class="fas fa-check-circle me-2"></i>
                        ¡Todos los productos tienen stock suficiente!
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-striped table-hover">
                            <thead class="table-dark">
                                <tr>
                                    <th>Producto</th>
                                    <th>Categoría</th>
                                    <th class="text-center">Stock Actual</th>
                                    <th class="text-center">Stock Mínimo</th>
                                    <th class="text-center">Faltante</th>
                                    <th>Acción</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var prod in reporte.Productos)
                                {
                                    <tr class="table-warning">
                                        <td class="fw-bold">@prod.Producto</td>
                                        <td>@prod.Categoria</td>
                                        <td class="text-center">@prod.StockActual</td>
                                        <td class="text-center">@prod.StockMinimo</td>
                                        <td class="text-center fw-bold text-danger">@prod.Faltante</td>
                                        <td>
                                            <button class="btn btn-sm btn-success" @onclick="() => IrAComprar(prod.IdProducto)">
                                                <i class="fas fa-cart-plus me-1"></i> Comprar
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    }
</div>

@code {
    private ReporteStockBajoDTO? reporte;
    private bool cargando = true;

    protected override async Task OnInitializedAsync()
    {
        await CargarReporte();
    }

    private async Task CargarReporte()
    {
        cargando = true;
        StateHasChanged();

        var respuesta = await ReportesService.GetStockBajo();
        if (!respuesta.Error)
        {
            reporte = respuesta.Respuesta;
        }
        else
        {
            await JS.InvokeVoidAsync("alert", "Error al cargar el reporte");
        }

        cargando = false;
        StateHasChanged();
    }

    private async Task ExportarExcel()
    {
        try
        {
            string url = $"/api/Exportar/stock-bajo/excel";
            await JS.InvokeVoidAsync("open", url, "_blank");
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("alert", $"Error al exportar: {ex.Message}");
        }
    }

    private void IrAComprar(int idProducto)
    {
        Navigation.NavigateTo($"/compras/nueva?producto={idProducto}");
    }

    private void Volver()
    {
        Navigation.NavigateTo("/");
    }
}