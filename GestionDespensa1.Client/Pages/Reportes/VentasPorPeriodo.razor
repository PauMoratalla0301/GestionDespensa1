@page "/reportes/ventas"
@using GestionDespensa1.Client.Servicios.Entidades
@using GestionDespensa1.Shared.DTO
@inject IReportesService ReportesService
@inject NavigationManager Navigation
@inject IJSRuntime JS

<PageTitle>Ventas por Período - Gestión Despensa</PageTitle>

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="mb-0">
            <i class="fas fa-chart-line text-success me-2"></i>
            Ventas por Período
        </h2>
        <button class="btn btn-outline-secondary" @onclick="Volver">
            <i class="fas fa-arrow-left me-1"></i> Volver
        </button>
    </div>

    <!-- Filtros -->
    <div class="card mb-4 shadow">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0"><i class="fas fa-filter me-2"></i>Seleccionar Período</h5>
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-5">
                    <label class="form-label fw-bold">Fecha Inicio</label>
                    <input type="date" @bind="fechaInicio" class="form-control" />
                </div>
                <div class="col-md-5">
                    <label class="form-label fw-bold">Fecha Fin</label>
                    <input type="date" @bind="fechaFin" class="form-control" />
                </div>
                <div class="col-md-2 d-flex align-items-end">
                    <button class="btn btn-success w-100" @onclick="CargarReporte" disabled="@cargando">
                        <i class="fas fa-search me-2"></i> Buscar
                    </button>
                </div>
            </div>
        </div>
    </div>

    @if (cargando)
    {
        <div class="text-center p-5">
            <div class="spinner-border text-success" style="width: 3rem; height: 3rem;" role="status">
                <span class="visually-hidden">Cargando...</span>
            </div>
            <p class="mt-3">Generando reporte...</p>
        </div>
    }
    else if (reporte != null)
    {
        <!-- Resumen -->
        <div class="row mb-4">
            <div class="col-md-3">
                <div class="card text-white bg-primary">
                    <div class="card-body">
                        <h6 class="card-title">Total Ventas</h6>
                        <h3 class="mb-0">@reporte.TotalVentas</h3>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card text-white bg-success">
                    <div class="card-body">
                        <h6 class="card-title">Total Ingresos</h6>
                        <h3 class="mb-0">@reporte.TotalIngresos.ToString("C")</h3>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card text-white bg-info">
                    <div class="card-body">
                        <h6 class="card-title">Período</h6>
                        <h5 class="mb-0">@reporte.FechaInicio.ToString("dd/MM/yyyy")</h5>
                        <h5>@reporte.FechaFin.ToString("dd/MM/yyyy")</h5>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card bg-warning">
                    <div class="card-body">
                        <h6 class="card-title">Exportar</h6>
                        <button class="btn btn-light btn-sm w-100" @onclick="ExportarExcel">
                            <i class="fas fa-file-excel me-2"></i> Exportar a Excel
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Tabla de ventas -->
        <div class="card shadow">
            <div class="card-header bg-success text-white">
                <h5 class="mb-0"><i class="fas fa-list me-2"></i>Detalle de Ventas</h5>
            </div>
            <div class="card-body">
                @if (!reporte.Ventas.Any())
                {
                    <div class="alert alert-info">No hay ventas en el período seleccionado</div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-striped table-hover">
                            <thead class="table-dark">
                                <tr>
                                    <th>#</th>
                                    <th>Fecha</th>
                                    <th>Cliente</th>
                                    <th>Total</th>
                                    <th>Método</th>
                                    <th>Estado</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var venta in reporte.Ventas)
                                {
                                    <tr>
                                        <td>@venta.Id</td>
                                        <td>@venta.Fecha.ToString("dd/MM/yyyy HH:mm")</td>
                                        <td>@venta.Cliente</td>
                                        <td class="fw-bold text-success">@venta.Total.ToString("C")</td>
                                        <td>@venta.MetodoPago</td>
                                        <td>
                                            <span class="badge @GetEstadoBadge(venta.Estado)">@venta.Estado</span>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    }
</div>

@code {
    private DateTime fechaInicio = DateTime.Today.AddDays(-30);
    private DateTime fechaFin = DateTime.Today;
    private ReporteVentasDTO? reporte;
    private bool cargando = false;

    private async Task CargarReporte()
    {
        cargando = true;
        StateHasChanged();

        var respuesta = await ReportesService.GetVentasPorPeriodo(fechaInicio, fechaFin);
        if (!respuesta.Error)
        {
            reporte = respuesta.Respuesta;
        }
        else
        {
            await JS.InvokeVoidAsync("alert", "Error al cargar el reporte");
        }

        cargando = false;
        StateHasChanged();
    }

    private async Task ExportarExcel()
    {
        try
        {
            string url = $"/api/Exportar/ventas/excel?fechaInicio={fechaInicio:yyyy-MM-dd}&fechaFin={fechaFin:yyyy-MM-dd}";
            await JS.InvokeVoidAsync("open", url, "_blank");
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("alert", $"Error al exportar: {ex.Message}");
        }
    }

    private string GetEstadoBadge(string estado)
    {
        return estado switch
        {
            "Pagado" => "bg-success",
            "Pendiente" => "bg-warning",
            "Parcial" => "bg-info",
            "Cancelado" => "bg-danger",
            _ => "bg-secondary"
        };
    }

    private void Volver()
    {
        Navigation.NavigateTo("/");
    }
}