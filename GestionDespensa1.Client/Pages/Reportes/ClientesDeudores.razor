@page "/reportes/deudores"
@using GestionDespensa1.Client.Servicios.Entidades
@using GestionDespensa1.Shared.DTO
@inject IReportesService ReportesService
@inject NavigationManager Navigation
@inject IJSRuntime JS

<PageTitle>Clientes Deudores - Gestión Despensa</PageTitle>

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="mb-0">
            <i class="fas fa-users text-danger me-2"></i>
            Clientes Deudores
        </h2>
        <div>
            <button class="btn btn-success me-2" @onclick="ExportarExcel">
                <i class="fas fa-file-excel me-1"></i> Exportar a Excel
            </button>
            <button class="btn btn-outline-secondary" @onclick="Volver">
                <i class="fas fa-arrow-left me-1"></i> Volver
            </button>
        </div>
    </div>

    @if (cargando)
    {
        <div class="text-center p-5">
            <div class="spinner-border text-success" style="width: 3rem; height: 3rem;" role="status">
                <span class="visually-hidden">Cargando...</span>
            </div>
            <p class="mt-3">Cargando deudores...</p>
        </div>
    }
    else if (reporte == null)
    {
        <div class="alert alert-danger">Error al cargar el reporte</div>
    }
    else
    {
        <!-- Resumen -->
        <div class="row mb-4">
            <div class="col-md-6">
                <div class="card text-white bg-danger">
                    <div class="card-body">
                        <h6 class="card-title">Total Deuda General</h6>
                        <h3 class="mb-0">@reporte.TotalGeneral.ToString("C")</h3>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="card text-white bg-warning">
                    <div class="card-body">
                        <h6 class="card-title">Clientes Deudores</h6>
                        <h3 class="mb-0">@reporte.CantidadDeudores</h3>
                    </div>
                </div>
            </div>
        </div>

        <!-- Lista de deudores -->
        <div class="card shadow">
            <div class="card-header bg-danger text-white">
                <h5 class="mb-0"><i class="fas fa-list me-2"></i>Lista de Deudores</h5>
            </div>
            <div class="card-body">
                @if (!reporte.Deudores.Any())
                {
                    <div class="alert alert-success">
                        <i class="fas fa-check-circle me-2"></i>
                        ¡No hay clientes con saldo pendiente!
                    </div>
                }
                else
                {
                    @foreach (var deudor in reporte.Deudores)
                    {
                        <div class="card mb-3 border-danger">
                            <div class="card-header bg-danger text-white">
                                <div class="d-flex justify-content-between align-items-center">
                                    <h6 class="mb-0">@deudor.Cliente</h6>
                                    <span class="badge bg-light text-dark">Deuda: @deudor.SaldoPendiente.ToString("C")</span>
                                </div>
                            </div>
                            <div class="card-body">
                                <p>
                                    <i class="fas fa-phone me-2"></i> @(!string.IsNullOrEmpty(deudor.Telefono) ? deudor.Telefono : "No especificado")<br />
                                    <i class="fas fa-envelope me-2"></i> @(!string.IsNullOrEmpty(deudor.Email) ? deudor.Email : "No especificado")
                                </p>
                                <h6>Ventas pendientes:</h6>
                                <div class="table-responsive">
                                    <table class="table table-sm">
                                        <thead>
                                            <tr>
                                                <th># Venta</th>
                                                <th>Fecha</th>
                                                <th class="text-end">Total</th>
                                                <th class="text-end">Pagado</th>
                                                <th class="text-end">Saldo</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var venta in deudor.Ventas)
                                            {
                                                <tr>
                                                    <td>@venta.IdVenta</td>
                                                    <td>@venta.Fecha.ToString("dd/MM/yyyy")</td>
                                                    <td class="text-end">@venta.Total.ToString("C")</td>
                                                    <td class="text-end">@venta.Pagado.ToString("C")</td>
                                                    <td class="text-end fw-bold text-danger">@venta.Saldo.ToString("C")</td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                                <button class="btn btn-sm btn-primary mt-2" @onclick="() => IrACliente(deudor.IdCliente)">
                                    <i class="fas fa-eye me-1"></i> Ver Cliente
                                </button>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>
    }
</div>

@code {
    private ReporteDeudoresDTO? reporte;
    private bool cargando = true;

    protected override async Task OnInitializedAsync()
    {
        await CargarReporte();
    }

    private async Task CargarReporte()
    {
        cargando = true;
        StateHasChanged();

        var respuesta = await ReportesService.GetClientesDeudores();
        if (!respuesta.Error)
        {
            reporte = respuesta.Respuesta;
        }
        else
        {
            await JS.InvokeVoidAsync("alert", "Error al cargar el reporte");
        }

        cargando = false;
        StateHasChanged();
    }

    private async Task ExportarExcel()
    {
        try
        {
            string url = $"/api/Exportar/deudores/excel";
            await JS.InvokeVoidAsync("open", url, "_blank");
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("alert", $"Error al exportar: {ex.Message}");
        }
    }

    private void IrACliente(int idCliente)
    {
        Navigation.NavigateTo($"/clientes/editar/{idCliente}");
    }

    private void Volver()
    {
        Navigation.NavigateTo("/");
    }
}